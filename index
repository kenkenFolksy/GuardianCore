<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GuardianCore - Discord Security Bot</title>
    <style>
        /* 全体のリセットと共通設定 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Helvetica Neue', Arial, sans-serif;
        }

        body {
            background-color: #0b0f17;
            color: #e2e8f0;
            line-height: 1.6;
        }

        a {
            color: #00f0ff;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        a:hover {
            color: #00bfff;
        }

        .container {
            width: 90%;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* ヘッダー */
        header {
            background-color: rgba(11, 15, 23, 0.9);
            border-bottom: 1px solid rgba(0, 240, 255, 0.2);
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: #00f0ff;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .logo-icon {
            width: 32px;
            height: 32px;
            background: radial-gradient(circle, #00f0ff 0%, #0b0f17 70%);
            border: 2px solid #00f0ff;
            border-radius: 50%;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 20px;
            align-items: center;
        }

        nav a, nav .menu-trigger {
            color: #94a3b8;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        nav a:hover, nav .menu-trigger:hover {
            color: #00f0ff;
        }

        /* メインビジュアル（ヒーローセクション） */
        .hero {
            padding: 180px 0 100px 0;
            text-align: center;
            background: radial-gradient(circle at center, rgba(0, 240, 255, 0.1) 0%, rgba(11, 15, 23, 0) 70%);
        }

        .hero h1 {
            font-size: 3.5rem;
            color: #ffffff;
            margin-bottom: 20px;
            text-shadow: 0 0 20px rgba(0, 240, 255, 0.5);
        }

        .hero p {
            font-size: 1.25rem;
            color: #94a3b8;
            max-width: 600px;
            margin: 0 auto 40px auto;
        }

        .btn {
            display: inline-block;
            background: linear-gradient(135deg, #00f0ff 0%, #0077ff 100%);
            color: #0b0f17;
            padding: 15px 35px;
            border-radius: 30px;
            font-weight: bold;
            font-size: 1.1rem;
            box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 25px rgba(0, 240, 255, 0.7);
            color: #ffffff;
        }

        /* セクション共通 */
        section {
            padding: 80px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        section h2 {
            font-size: 2rem;
            text-align: center;
            margin-bottom: 50px;
            color: #ffffff;
            position: relative;
        }

        section h2::after {
            content: '';
            display: block;
            width: 50px;
            height: 3px;
            background-color: #00f0ff;
            margin: 10px auto 0 auto;
            border-radius: 2px;
        }

        /* 特徴・機能（カードデザイン） */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .feature-card {
            background-color: #111827;
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-top: 3px solid #00f0ff;
            padding: 30px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .feature-card:hover {
            transform: translateY(-5px);
            border-color: #00f0ff;
            box-shadow: 0 10px 20px rgba(0, 240, 255, 0.1);
        }

        .feature-card h3 {
            font-size: 1.3rem;
            color: #ffffff;
            margin-bottom: 15px;
        }

        .feature-card p {
            color: #94a3b8;
            font-size: 0.95rem;
        }

        /* コマンド一覧（テーブルデザイン） */
        .table-wrapper {
            overflow-x: auto;
            background-color: #111827;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        th, td {
            padding: 15px 20px;
        }

        th {
            background-color: rgba(0, 240, 255, 0.1);
            color: #00f0ff;
            font-weight: bold;
            border-bottom: 2px solid rgba(0, 240, 255, 0.2);
        }

        tr {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        tr:last-child {
            border-bottom: none;
        }

        tr:hover {
            background-color: rgba(255, 255, 255, 0.02);
        }

        .cmd-container {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .cmd-name {
            font-family: monospace;
            color: #00f0ff;
            background-color: rgba(0, 240, 255, 0.05);
            padding: 4px 8px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 0.95rem;
        }

        /* コピーボタンのスタイル */
        .copy-btn {
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 240, 255, 0.3);
            color: #94a3b8;
            padding: 2px 6px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.8rem;
            transition: all 0.2s ease;
        }

        .copy-btn:hover {
            background-color: rgba(0, 240, 255, 0.1);
            color: #00f0ff;
            border-color: #00f0ff;
        }

        .copy-btn.copied {
            background-color: rgba(0, 255, 128, 0.1);
            color: #00ff80;
            border-color: #00ff80;
        }

        /* モーダル（規約ポップアップ）のスタイル */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background-color: #111827;
            border: 1px solid #00f0ff;
            width: 90%;
            max-width: 700px;
            max-height: 80%;
            border-radius: 12px;
            padding: 30px;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 0 30px rgba(0, 240, 255, 0.2);
        }

        .modal-close {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 1.5rem;
            color: #94a3b8;
            cursor: pointer;
        }

        .modal-close:hover {
            color: #ffffff;
        }

        .modal-content h3 {
            color: #ffffff;
            font-size: 1.5rem;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(0, 240, 255, 0.3);
            padding-bottom: 10px;
        }

        .modal-body {
            color: #94a3b8;
            font-size: 0.95rem;
            text-align: left;
            white-space: pre-wrap;
        }

        .modal-body h4 {
            color: #e2e8f0;
            margin: 15px 0 5px 0;
        }

        /* フッター */
        footer {
            background-color: #070a10;
            padding: 40px 0;
            text-align: center;
            color: #64748b;
            font-size: 0.9rem;
        }

        .footer-links {
            margin-bottom: 20px;
        }

        .footer-links a, .footer-links span {
            margin: 0 15px;
            font-weight: 500;
            cursor: pointer;
        }

        .footer-links span:hover {
            color: #00f0ff;
        }

        /* レスポンシブ（スマホ対応） */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            header .container { flex-direction: column; gap: 15px; padding: 15px 0; }
            nav ul { gap: 12px; flex-wrap: wrap; justify-content: center; }
            nav a, nav .menu-trigger { font-size: 0.9rem; }
            td { padding: 12px 10px; }
            .cmd-container { flex-direction: column; align-items: flex-start; gap: 5px; }
            .footer-links { display: flex; flex-direction: column; gap: 10px; }
        }
    </style>
</head>
